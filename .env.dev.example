NODE_ENV=development
COMPOSE_FILE=docker-compose.dev.yml

# Database Container Settings
POSTGRES_DB=rugradar_dev
POSTGRES_USER=dev
POSTGRES_PASSWORD=dev
DB_PORT=5432

# Database (connects to dev/staging database container)
DATABASE_URL=postgresql://dev:dev@postgres:5432/rugradar_dev

# Redis Container Settings
REDIS_PORT=6379

# Redis (connects to dev/staging redis)
REDIS_URL=redis://redis:6379

# Base Sepolia RPC
RPC_URL=https://sepolia.base.org

# LLM Provider
LLM_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o-mini

# EAS (Address on Base Sepolia)
EAS_CONTRACT_ADDRESS=0x4200000000000000000000000000000000000021

# Server
PORT=3000
LOG_LEVEL=info

# Security
API_KEY_SALT=dev-salt-change-me

# Contract Addresses for Base Sepolia
OWNER_ADDRESS=
AGENT_ADDRESS=
ORACLE_ADDRESS=
