NODE_ENV=development

# Database (connects to local postgres container)
DATABASE_URL=postgresql://dev:dev@localhost:5432/rugradar_dev

# Redis (connects to local redis container)
REDIS_URL=redis://localhost:6379

# Base Local RPC (connects to local Anvil container)
RPC_URL=http://localhost:8545

# LLM Provider
LLM_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o-mini

# EAS (Address on Local chain / Mock)
EAS_CONTRACT_ADDRESS=0x4200000000000000000000000000000000000021

# Server
PORT=3000
LOG_LEVEL=debug

# Security
API_KEY_SALT=local-salt-change-me

# Contract Addresses for Local Testing
OWNER_ADDRESS=0x1760Dd16B6a84665Ea3b097a96DAb47677a99A85 
AGENT_ADDRESS=0xb1FdADbFBA264871511c2a9b4F55CE78D11bbFc7
ORACLE_ADDRESS=0x8115bf284Fa3cc3f4387c77d28FAD53b42d7EB7B
