NODE_ENV=production

# Database (connects to production database)
DATABASE_URL=postgresql://prod_user:secure_password@postgres:5432/rugradar_prod

# Redis (connects to production redis)
REDIS_URL=redis://redis:6379

# Base Mainnet RPC
RPC_URL=https://mainnet.base.org

# LLM Provider
LLM_API_KEY=sk-your-production-key-here
LLM_MODEL=gpt-4o

# EAS (Address on Base Mainnet)
EAS_CONTRACT_ADDRESS=0x4200000000000000000000000000000000000021

# Server
PORT=3000
LOG_LEVEL=warn

# Security (MUST generate a secure value using: openssl rand -hex 32)
API_KEY_SALT=generate-secure-salt-for-production

# Contract Addresses for Base Mainnet
OWNER_ADDRESS=
AGENT_ADDRESS=
ORACLE_ADDRESS=
